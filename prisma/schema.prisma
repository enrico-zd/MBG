generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())

  projects  Project[]
  assets    Asset[]
  adJobs    AdJob[]
}

model Project {
  id        String   @id @default(uuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  assets    Asset[]
  adJobs    AdJob[]
}

model Asset {
  id             String   @id @default(uuid())
  userId         String
  projectId      String
  originalPath   String
  derived9x16Path String
  mimeType       String
  width          Int
  height         Int
  sizeBytes      BigInt
  createdAt      DateTime @default(now())
  deletedAt      DateTime?

  project        Project  @relation(fields: [projectId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
}

enum AdJobStatus {
  queued
  running
  done
  failed
  cancelled
}

model AdJob {
  id        String     @id @default(uuid())
  userId    String
  projectId String
  status    AdJobStatus @default(queued)

  targetDurationSec        Int
  quality                  String
  generateAudio            Boolean @default(false)
  templatePackId           String
  paramsJson               Json
  estimatedPixverseCredits Int

  createdAt DateTime @default(now())
  startedAt DateTime?
  finishedAt DateTime?
  failureCode String?
  failureMessage String?

  project  Project  @relation(fields: [projectId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  segments AdJobSegment[]
}

enum SegmentStatus {
  queued
  uploading
  generating
  polling
  done
  failed
}

model AdJobSegment {
  id              String       @id @default(uuid())
  adJobId         String
  segmentIndex    Int
  durationSec     Int

  pixverseImgId   BigInt?
  pixverseVideoId BigInt?
  pixverseStatus  Int?

  status          SegmentStatus @default(queued)
  promptFinal     String
  segmentVideoPath String?

  createdAt       DateTime @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?
  failureCode     String?
  failureMessage  String?

  adJob           AdJob    @relation(fields: [adJobId], references: [id])

  @@unique([adJobId, segmentIndex])
}

enum TaskStatus {
  queued
  running
  done
  failed
}

model Task {
  id         String     @id @default(uuid())
  type       String
  payloadJson Json
  status     TaskStatus @default(queued)

  runAfter   DateTime   @default(now())
  attempts   Int        @default(0)
  lastError  String?

  lockedAt   DateTime?
  lockedBy   String?

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}
